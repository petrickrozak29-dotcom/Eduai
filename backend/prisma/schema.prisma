// Prisma schema for EduPath-AI
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SISWA
  GURU
  DEVELOPER
}

enum ClassPhase {
  E
  F
}

enum PhaseFSpecialization {
  MIPA
  IPS
  BAHASA
  VOKASI
}

enum PretestLevel {
  TIDAK_PAHAM
  KURANG_PAHAM
  PAHAM
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(SISWA)
  nip       String?  @unique
  nis       String?  @unique
  kelas     String?
  avatar    String?
  tempatLahir String?
  tanggalLahir DateTime?
  jenisKelamin String?
  agama     String?
  alamat    String?
  noHP      String?
  pendidikanTerakhir String?
  perguruanTinggi String?
  programStudi String?
  tahunLulus Int?
  nuptk     String?
  statusKepegawaian String?
  instansi  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher   Teacher?
  student   Student?
  developer Developer?
  forums    Forum[]
  forumReplies ForumReply[]
  events    Event[]
  systemLogs SystemLog[]
}

model Teacher {
  id          String   @id @default(uuid())
  userId      String   @unique
  nip         String   @unique
  mataPelajaran String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects  Subject[]  @relation("TeacherSubjects")
  kelasList Kelas[]
}

model Student {
  id        String   @id @default(uuid())
  userId    String   @unique
  nis       String   @unique
  kelas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningProfile LearningProfile?
  results         Result[]
  classEnrollments ClassStudent[]
}

model Developer {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Kelas {
  id             String   @id @default(uuid())
  name           String
  classCode      String   @unique
  phase          ClassPhase
  classLevel     String?
  specialization PhaseFSpecialization?
  category       String   @default("umum")
  teacherId      String
  subjectId      String?
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teacher       Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject       Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  enrollments   ClassStudent[]
  materials     ClassMaterial[]
  events        Event[]
  forums        Forum[]
  quizzes       Quiz[]
}

model ClassStudent {
  id        String   @id @default(uuid())
  kelasId   String
  studentId String
  pretestScore Int?
  pretestLevel PretestLevel?
  learningIndex Float? @default(0)
  joinedAt  DateTime @default(now())

  kelas   Kelas   @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([kelasId, studentId])
}

model ClassMaterial {
  id         String   @id @default(uuid())
  kelasId    String
  materialId String
  isPublished Boolean @default(false)
  createdAt  DateTime @default(now())

  kelas    Kelas    @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([kelasId, materialId])
}

model Subject {
  id          String   @id @default(uuid())
  name        String
  description String?
  kelas       String?
  teacherId   String?
  imageUrl    String?
  category    String   @default("umum")
  specialization PhaseFSpecialization?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher   Teacher?          @relation("TeacherSubjects", fields: [teacherId], references: [id])
  chapters  Chapter[]
  materials Material[]
  quizzes   Quiz[]
  forums    Forum[]
  kelasList Kelas[]
}

model Chapter {
  id        String   @id @default(uuid())
  subjectId String
  title     String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject   Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  materials Material[]
  quizzes   Quiz[]
}

model Material {
  id          String   @id @default(uuid())
  subjectId   String
  chapterId   String?
  title       String
  content     String   @default("")
  contentType String   @default("text")
  imageUrl    String?
  fileUrl     String?
  level       PretestLevel?
  babQuizCount Int?    @default(10)
  finalQuizCount Int?  @default(20)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject    Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter    Chapter?        @relation(fields: [chapterId], references: [id])
  classMaterials ClassMaterial[]
}

model Quiz {
  id        String   @id @default(uuid())
  chapterId String?
  subjectId String
  kelasId   String?
  title     String
  type      String   @default("bab")
  isPretest Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapter Chapter? @relation(fields: [chapterId], references: [id])
  subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  kelas   Kelas?   @relation(fields: [kelasId], references: [id], onDelete: SetNull)
  questions Question[]
  results   Result[]
}

model Question {
  id        String   @id @default(uuid())
  quizId    String
  text      String   @default("")
  options   String   @default("{}")
  correctAnswer String @default("A")
  points    Int      @default(10)
  createdAt DateTime @default(now())

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]
}

model Answer {
  id         String   @id @default(uuid())
  questionId String
  resultId   String
  answer     String   @default("")
  isCorrect  Boolean  @default(false)
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  result   Result   @relation(fields: [resultId], references: [id], onDelete: Cascade)
}

model Result {
  id          String   @id @default(uuid())
  studentId   String
  quizId      String
  score       Int      @default(0)
  totalPoints Int      @default(0)
  percentage  Float    @default(0)
  pretestLevel PretestLevel?
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quiz    Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]
}

model LearningProfile {
  id             String   @id @default(uuid())
  studentId      String   @unique
  learningStyle  String?
  cognitiveLevel String?
  pretestScore   Int?
  learningIndex  Float?   @default(0)
  recommendations Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Forum {
  id        String   @id @default(uuid())
  kelasId   String?
  subjectId String?
  userId    String
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kelas   Kelas?        @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject?      @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  replies ForumReply[]
}

model ForumReply {
  id        String   @id @default(uuid())
  forumId   String
  userId    String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id          String     @id @default(uuid())
  title       String
  description String?    @default("")
  date        DateTime   @default(now())
  type        String     @default("academic")
  category    String?    @default("academic")
  penyelenggara String?
  photoUrl    String?
  link        String?
  userId      String
  kelasId     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  kelas Kelas? @relation(fields: [kelasId], references: [id], onDelete: SetNull)
}

model SystemLog {
  id        String   @id @default(uuid())
  action    String   @default("")
  userId    String?
  details   Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
